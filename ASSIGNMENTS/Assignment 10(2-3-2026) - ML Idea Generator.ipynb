    "Problem: Disease Prediction System\n",
    "\n",
    "Problem Statement: Predict the likelihood of a disease based on symptoms and medical history.\n",
    "\n",
    "Input:\n",
    "Age\n",
    "Blood pressure\n",
    "Sugar level\n",
    "Cholesterol\n",
    "Symptoms (fever, fatigue, headache, etc.)\n",
    "\n",
    "Output:\n",
    "Disease Type\n",
    "OR\n",
    "Disease Risk Percentage\n",
    "\n",
    "ML Type: Classification"
   ]
  },
