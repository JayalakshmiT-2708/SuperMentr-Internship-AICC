   "source": [
    " \n",
    "Problem: Student Performance Prediction System\n",
    "\n",
    "Problem Statement: Predict whether a student is likely to pass or fail based on academic and behavioral data.\n",
    "\n",
    "Input:\n",
    "Attendance percentage\n",
    "Internal marks\n",
    "Assignment completion rate\n",
    "Study hours per week\n",
    "Previous semester GPA\n",
    "\n",
    "Output:\n",
    "Pass / Fail (Classification)\n",
    "OR\n",
    "Predicted Final Score (Regression)\n",
    "\n",
    "ML Type: Supervised Learning (Classification or Regression)"
   ]
  },
  {
   "cell_type": "raw",
   "id": "573697c0-541e-46bd-a766-633433c70d93",
   "metadata": {},
   "source": [
    "Problem: Placement Prediction System\n",
    "\n",
    "Problem Statement: Predict whether a student will get placed in campus recruitment.\n",
    "\n",
    "Input:\n",
    "CGPA\n",
    "Technical skills score\n",
    "Aptitude test score\n",
    "Communication skills rating\n",
    "Internship experience (Yes/No)\n",
    "\n",
    "Output:\n",
    "Placed / Not Placed (Binary Classification)"
   ]
  },
